# ================================================
# 🔥 Backend Node/Express ignores
# ================================================
node_modules/
dist/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compilados del panel admin
public/bundle.js
public/build/
public/*.map

# UI Build Tools
bundle.js
build-ui.js.map

# PM2 logs
.pids
logs/

# ================================================
# 🔐 Environment files (NO SE SUBEN)
# ================================================
.env
.env.*
!.env.example       # pero sí permitir subir un archivo ejemplo

# ================================================
# 🧹 IDE settings
# ================================================
.vscode/
.idea/
*.swp


# ================================================
# 🐧 Sistemas operativos
# ================================================
.DS_Store
Thumbs.db

# ================================================
# 🧰 Go project ignores
# ================================================
GoApp/bin/
GoApp/build/
GoApp/*.exe
GoApp/*.dll

# Archivos temporales de Go
*.test
*.out

# ================================================
# 🔗 PostgreSQL dump files
# ================================================
*.sql

# ================================================
# ⚡ Parcel/webpack/craco
# ================================================
.cache/
parcel-cache/

# ================================================
# 🔐 Claves y certificados
# ================================================
*.pem
*.key
*.crt

